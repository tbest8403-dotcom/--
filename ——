local function switchTab(tab)
	if switching or busy then
		return
	end

	switching = true

	if tab == "Main" then
		MainTab.TextColor3 = Color3.fromRGB(255, 255, 255)
		MechanicsTab.TextColor3 = Color3.fromRGB(160, 160, 160)
		InfoTab.TextColor3 = Color3.fromRGB(160, 160, 160)

		tween(Selector, TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 2, 0, 2)
		})

		tween(MainPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 0, 0)
		})
		tween(MechanicsPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(1, 30, 0, 0)
		})
		local done = tween(InfoPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(1, 30, 0, 0)
		})
		done.Completed:Wait()
	elseif tab == "Mechanics" then
		MainTab.TextColor3 = Color3.fromRGB(160, 160, 160)
		MechanicsTab.TextColor3 = Color3.fromRGB(255, 255, 255)
		InfoTab.TextColor3 = Color3.fromRGB(160, 160, 160)

		tween(Selector, TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(1/3, 2, 0, 2)
		})

		tween(MainPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(-1, -30, 0, 0)
		})
		tween(MechanicsPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 0, 0)
		})
		local done = tween(InfoPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(1, 30, 0, 0)
		})
		done.Completed:Wait()
	else
		MainTab.TextColor3 = Color3.fromRGB(160, 160, 160)
		MechanicsTab.TextColor3 = Color3.fromRGB(160, 160, 160)
		InfoTab.TextColor3 = Color3.fromRGB(255, 255, 255)

		tween(Selector, TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(2/3, 2, 0, 2)
		})

		tween(MainPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(-1, -30, 0, 0)
		})
		tween(MechanicsPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(-1, -30, 0, 0)
		})
		local done = tween(InfoPage, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 0, 0)
		})
		done.Completed:Wait()
	end

	switching = false
end

