		titleLabel.Parent = card

		local descLabel = Instance.new("TextLabel")
		descLabel.BackgroundTransparency = 1
		descLabel.Position = UDim2.new(0, 12, 0, 34)
		descLabel.Size = UDim2.new(1, -24, 0, 0)
		descLabel.AutomaticSize = Enum.AutomaticSize.Y
		descLabel.Text = descText
		descLabel.TextWrapped = true
		descLabel.TextColor3 = Color3.fromRGB(170, 170, 170)
		descLabel.Font = Enum.Font.Gotham
		descLabel.TextSize = 13
		descLabel.TextXAlignment = Enum.TextXAlignment.Left
		descLabel.TextYAlignment = Enum.TextYAlignment.Top
		descLabel.Parent = card

		local bottomPad = Instance.new("UIPadding")
		bottomPad.PaddingBottom = UDim.new(0, 12)
		bottomPad.Parent = card

		return card
	end

	return api
end

