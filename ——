CloseButton.MouseLeave:Connect(function()
	if opened and not busy then
		tween(CloseButton, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = Color3.fromRGB(35, 35, 35)
		})
	end
end)

local function closeUI()
	if busy or not opened then
		return
	end

	busy = true
	opened = false

	MiniLogo.Position = logoPos
	MiniLogo.Size = UDim2.new(0, 20, 0, 20)
	MiniLogo.BackgroundTransparency = 1
	MiniLogo.TextTransparency = 1
	MiniLogo.Visible = true

	tween(Title, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1})
	tween(TabsHolder, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
	tween(Selector, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
	tween(MainTab, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1})
	tween(MechanicsTab, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1})
	tween(InfoTab, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1})
	tween(CloseButton, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
		TextTransparency = 1
	})

	task.wait(0.05)

	local shrink = tween(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), {
		Size = closedSize,
		Position = logoPos,
		BackgroundTransparency = 1
	})

	tween(MiniLogo, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), {
		Size = closedSize,
		Position = logoPos,
		BackgroundTransparency = 0,
		TextTransparency = 0
	})

	shrink.Completed:Wait()
	Main.Visible = false
	ContentHolder.Visible = false

	busy = false
end

local function openUI()
	if busy or opened then
		return
	end

	busy = true
	opened = true

	Main.Position = centerPos
	Main.Size = closedSize
	Main.BackgroundTransparency = 1
	Main.Visible = true
	ContentHolder.Visible = true

	Title.TextTransparency = 1
	TabsHolder.BackgroundTransparency = 1
	Selector.BackgroundTransparency = 1
	MainTab.TextTransparency = 1
	MechanicsTab.TextTransparency = 1
	InfoTab.TextTransparency = 1
	CloseButton.BackgroundTransparency = 1
	CloseButton.TextTransparency = 1

	local grow = tween(Main, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = openSize,
		Position = centerPos,
		BackgroundTransparency = 0
	})

	tween(MiniLogo, TweenInfo.new(0.32, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 20, 0, 20),
		BackgroundTransparency = 1,
		TextTransparency = 1
	})

	task.wait(0.1)

	tween(Title, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(TabsHolder, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
	tween(Selector, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
	tween(MainTab, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(MechanicsTab, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(InfoTab, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(CloseButton, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		TextTransparency = 0
	})

	grow.Completed:Wait()
	MiniLogo.Visible = false

	busy = false
end

CloseButton.MouseButton1Click:Connect(closeUI)
MiniLogo.MouseButton1Click:Connect(openUI)

